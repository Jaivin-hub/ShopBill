# --- Email (Nodemailer / real SMTP) ---
# Copy to .env and fill in. Remove Mailtrap values when going to production.

# Gmail (use an App Password: Google Account → Security → 2-Step → App passwords)
# EMAIL_USER must be @gmail.com unless your domain is on Google Workspace (then use user@yourdomain.com).
# If send hangs, try EMAIL_PORT=587 and EMAIL_SECURE=false (many hosts block outbound 465).
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=465
# EMAIL_SECURE=true
# EMAIL_USER=youraccount@gmail.com
# EMAIL_PASS=xxxx xxxx xxxx xxxx
# EMAIL_FROM=youraccount@gmail.com

# SendGrid (SMTP)
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USER=apikey
# EMAIL_PASS=SG.your_api_key_here
# EMAIL_FROM=hello@your-verified-domain.com

# Resend (SMTP)
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=465
# EMAIL_SECURE=true
# EMAIL_USER=resend
# EMAIL_PASS=re_your_api_key
# EMAIL_FROM=onboarding@resend.dev

# Optional
# EMAIL_FROM_NAME=Pocket POS
# EMAIL_REQUIRE_TLS=true
# EMAIL_TLS_REJECT_UNAUTHORIZED=true
# SMTP timeouts (ms) — fail faster instead of hanging
# EMAIL_CONNECTION_TIMEOUT_MS=15000
# EMAIL_GREETING_TIMEOUT_MS=10000
# EMAIL_SOCKET_TIMEOUT_MS=25000
# EMAIL_SEND_TIMEOUT_MS=45000   # max wait for sendMail(); logs timeout if SMTP never responds
# EMAIL_DEBUG=1   # verbose SMTP wire log (only when debugging)

# MongoDB, JWT, etc. (add your existing vars below)
# MONGODB_URI=
# JWT_SECRET=
# CLIENT_URL=https://your-app.com
